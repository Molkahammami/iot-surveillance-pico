    {
        "id": "tmpl2",
        "type": "template",
        "z": "6940f91a6dfb5380",
        "template": "<!DOCTYPE html><html><head><meta charset='UTF-8'><title>IoT</title><script>setInterval(async()=>{try{const r=await fetch('/data');const d=await r.json();document.getElementById('t').textContent=d.temp?.toFixed(1)||'--';document.getElementById('h').textContent=d.hum||'--';document.getElementById('a').textContent=d.air||'--';document.getElementById('l').textContent=d.lum||'--';document.getElementById('s').textContent=d.alerte?'ALERTE!':'OK';}catch(e){}},1000);</script></head><body style='background:#0a0e1a;color:#fff;font-family:sans-serif;padding:20px'><h1 style='color:#00d4ff'>Surveillance IoT</h1><div style='display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin:20px 0'><div style='background:#111827;padding:20px;border-radius:12px;border-top:2px solid #ff9f43'><div style='color:#6b7a99;font-size:12px'>TEMPÉRATURE</div><div id='t' style='font-size:36px;color:#ff9f43'>--</div><div style='color:#6b7a99'>°C</div></div><div style='background:#111827;padding:20px;border-radius:12px;border-top:2px solid #00d4ff'><div style='color:#6b7a99;font-size:12px'>HUMIDITÉ</div><div id='h' style='font-size:36px;color:#00d4ff'>--</div><div style='color:#6b7a99'>%</div></div><div style='background:#111827;padding:20px;border-radius:12px;border-top:2px solid #00ff88'><div style='color:#6b7a99;font-size:12px'>QUALITÉ AIR</div><div id='a' style='font-size:36px;color:#00ff88'>--</div><div style='color:#6b7a99'>ADC</div></div><div style='background:#111827;padding:20px;border-radius:12px;border-top:2px solid #ffd93d'><div style='color:#6b7a99;font-size:12px'>LUMINOSITÉ</div><div id='l' style='font-size:36px;color:#ffd93d'>--</div><div style='color:#6b7a99'>lux</div></div></div><div style='background:#111827;padding:20px;border-radius:12px;font-size:24px' id='s'>--</div></body></html>",
