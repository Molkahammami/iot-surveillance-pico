    {
        "id": "62fe161c79314a73",
        "type": "function",
        "z": "6940f91a6dfb5380",
        "name": "Dispatcher",
        "func": "var d = msg.payload;\nflow.set('lastData', d);\n\nvar alerte = (d.alerte === true || d.alerte === \"true\" || d.alerte === 1);\nvar hist = flow.get('alertes') || [];\n\nif (alerte) {\n    hist.unshift({\n        time: new Date().toLocaleTimeString(),\n        temp: d.temp,\n        hum: d.hum,\n        mvt: d.mvt ? 'OUI' : 'NON'\n    });\n    if (hist.length > 1440) hist = hist.slice(0, 1440);\n    flow.set('alertes', hist);\n}\n\nvar msgs = [null, null, null, null, null, null, null, null];\nmsgs[0] = { payload: d.temp };\nmsgs[1] = { payload: d.hum };\nmsgs[2] = { payload: d.air };\nmsgs[3] = { payload: d.lum };\nmsgs[4] = { payload: d.mvt ? 1 : 0 };\nmsgs[5] = { payload: alerte ? '🚨 ALERTE!' : '✅ Tout OK' };\nmsgs[6] = [{ payload: d.temp, topic: 'Température' }, { payload: d.hum, topic: 'Humidité' }];\nmsgs[7] = { payload: hist };\nreturn msgs;",
        "outputs": 8,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 530,
        "y": 240,
        "wires": [
